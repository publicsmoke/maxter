{
  "name": "maxter",
  "version": "0.8.2",
  "description": "Maxter — portable SSH/SFTP client for Windows",
  "author": "Maxter",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "make-icon": "node scripts/make-icon.js",
    "dist:win": "npm run make-icon && electron-builder --win portable --x64"
  },
  "dependencies": {
    "ssh2": "^1.15.0"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.99",
    "electron": "^31.3.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.maxter.term",
    "productName": "Maxter",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "app.js",
      "index.html",
      "styles.css",
      "package.json",
      "!**/*.md",
      "!dist/**",
      "!build/**",
      "!.git/**",
      "!.gitignore",
      "!scripts/**"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "Maxter-${version}-portable.${ext}",
      "executableName": "Maxter"
    },
    "portable": {
      "artifactName": "Maxter-${version}-portable.${ext}"
    }
  }
}
