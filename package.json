{
  "name": "nexus-term",
  "version": "0.1.0",
  "description": "Maxter — portable SSH/SFTP client for Windows",
  "author": "Maxter",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win portable --x64"
  },
  "dependencies": {
    "ssh2": "^1.15.0"
  },
  "devDependencies": {
    "electron": "^31.3.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.maxter.term",
    "productName": "Maxter",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "app.js",
      "index.html",
      "styles.css",
      "package.json",
      "!**/*.md",
      "!dist/**",
      "!build/**",
      "!.git/**",
      "!.gitignore",
      "!scripts/**"
    ],
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] }
      ],
      "artifactName": "Maxter-${version}-portable.${ext}",
      "executableName": "Maxter"
    },
    "portable": {
      "artifactName": "Maxter-${version}-portable.${ext}"
    }
  }
}
